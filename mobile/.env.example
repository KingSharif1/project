# Environment Configuration for Mobile App
# Copy this file to .env.development, .env.staging, and .env.production
# and fill in the appropriate values for each environment

# Environment (development, staging, production)
APP_ENV=production

# Backend API URL
# Development: http://YOUR_LOCAL_IP:3000/api/mobile
# Staging: https://staging-api.yourdomain.com/api/mobile
# Production: https://api.yourdomain.com/api/mobile
API_URL=https://api.yourdomain.com/api/mobile

# Supabase Configuration
SUPABASE_URL=https://ocjqsnocuqyumoltighi.supabase.co
